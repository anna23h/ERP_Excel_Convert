# === 数据目录：按目录整体忽略（首选，不靠扩展名猜）===
# 真实订单数据（含客户姓名/电话/地址等个人信息，绝不提交）
raw_data/
# 输出产物（统一 output/，按 output/YYYYMMDD 归档）
output/
输出/
# 测试/参考/历史数据
all_test_data/
test-data/
results/
# 因机器而异的本地配置
config.py

# === PII 兜底：任何位置的表格一律不提交（samples/ 显式放行脱敏样例）===
*.xlsx
*.ods
*.csv
!samples/
!samples/*.xlsx
!samples/*.csv

# PyInstaller 打包产物
build/
dist/
*.spec

# Python
__pycache__/
*.pyc
.venv/
venv/
.python-version

# macOS / 编辑器
.DS_Store
.idea/
.vscode/

# === 私有：开发过程文档，不对同事公开（本地保留，另走 Syncthing/私有 repo 同步）===
docs/
CLAUDE.md
ISSUES.md
SPEC.md
